# Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development
SERVER_URL=http://localhost:3000

# ============================================
# DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=restored_kings_db
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================
# STRIPE (Payment Processing)
# Get from: https://dashboard.stripe.com/apikeys
# ============================================
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_public_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# EMAIL CONFIGURATION
# Using SendGrid (recommended for nonprofits)
# Get from: https://sendgrid.com
# ============================================
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=SG.your_sendgrid_key_here
SENDGRID_FROM_EMAIL=noreply@restoredkings.org
ADMIN_EMAIL=admin@restoredkings.org
CONTACT_EMAIL=contact@restoredkings.org

# Alternative: Using Gmail
# EMAIL_SERVICE=gmail
# GMAIL_USER=your.email@gmail.com
# GMAIL_PASSWORD=your_app_password

# Alternative: Using Mailgun
# EMAIL_SERVICE=mailgun
# MAILGUN_API_KEY=key-your_mailgun_key
# MAILGUN_DOMAIN=mg.restoredkings.org

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
SESSION_SECRET=your_session_secret_change_this

# Password reset token expiry (minutes)
PASSWORD_RESET_EXPIRE=30

# ============================================
# SECURITY
# ============================================
# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://restoredkings.org
# CORS_ORIGINS=* # Only for development!

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# GOOGLE ANALYTICS
# Get from: https://analytics.google.com
# ============================================
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ============================================
# DOMAIN & URLS
# ============================================
DOMAIN=restoredkings.org
WEBSITE_URL=https://restoredkings.org
ADMIN_URL=https://restoredkings.org/admin

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ============================================
# FILE UPLOADS
# ============================================
UPLOAD_MAX_SIZE=10485760 # 10MB in bytes
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,application/pdf
UPLOAD_DIR=uploads

# AWS S3 (for file storage - optional)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_S3_BUCKET=restored-kings-bucket
# AWS_S3_REGION=us-east-1

# ============================================
# SOCIAL MEDIA
# ============================================
FACEBOOK_URL=https://facebook.com/restoredkings
TWITTER_URL=https://twitter.com/restoredkings
INSTAGRAM_URL=https://instagram.com/restoredkings
LINKEDIN_URL=https://linkedin.com/company/restoredkings

# ============================================
# NONPROFIT INFO
# ============================================
ORGANIZATION_NAME=Restored Kings Foundation
ORGANIZATION_EIN=12-3456789
ORGANIZATION_ADDRESS=123 Main St, City, ST 12345
ORGANIZATION_PHONE=(555) 123-4567

# ============================================
# DEVELOPMENT TOOLS
# ============================================
# Enable debug mode
DEBUG=false

# Mock email service (for development)
MOCK_EMAIL=false

# Seed database on startup
SEED_DATABASE=false

# Hot reload
HOT_RELOAD=true

# ============================================
# THIRD-PARTY SERVICES
# ============================================

# Form submission service (optional)
# FORM_SUBMISSION_SERVICE=zapier
# ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...

# SMS Alerts (optional)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE=+1234567890

# ============================================
# BACKUP & MAINTENANCE
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * * # 2 AM daily
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30

# ============================================
# NOTES
# ============================================
# ❗ IMPORTANT SECURITY REMINDERS:
# 1. NEVER commit .env file to git (add to .gitignore)
# 2. Use strong, unique values for all secrets
# 3. Rotate JWT_SECRET and SESSION_SECRET regularly
# 4. Use different values for production vs development
# 5. Keep API keys confidential and secure
# 6. Monitor for unauthorized access
# 7. Update dependencies regularly
# 8. Use HTTPS/SSL in production
# 9. Enable CORS only for trusted domains
# 10. Review security best practices regularly
