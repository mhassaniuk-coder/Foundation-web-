# Git Ignore File
# Files and folders to exclude from version control

# Environment variables
.env
.env.local
.env.*.local

# Node dependencies
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
.npm
.eslintcache

# Build files
dist/
build/
*.bundle.js
*.bundle.css

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# IDE files
*.sublime-project
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Cache
.cache/
.eslintcache
.stylelintcache
coverage/

# Database
*.db
*.sqlite
*.sqlite3

#  Backup files
*.bak
*.backup
*.tmp
*.temp

# OS compiled/generated files
.bundle/
vendor/ruby/

# Virtual environments
venv/
env/
.venv

# Docker
.dockerignore

# IDE generated files
out/
.gradle
.vscode
*.iml

# Test coverage
coverage/
.nyc_output/

# Package manager locks (optional - choose one strategy)
# package-lock.json  # Uncomment if using npm workspaces
# yarn.lock         # Uncomment if using yarn workspaces

# Files with sensitive info
secrets.json
private_keys/
.private/

# Upload directories (generated)
uploads/
temp/
tmp/

# System files
.thumbsdb
.DS_Store
